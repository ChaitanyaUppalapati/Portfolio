# Pipeline 2 (add-project CLI) — copy to .env and fill in.
# .env is gitignored; never commit real keys.

# Required: your OpenAI API key.
OPENAI_API_KEY=sk-...

# Optional: model used to draft project entries. Defaults to gpt-5.4-mini
# (balanced cost/performance for README→JSON extraction).
# OPENAI_MODEL=gpt-5.4-mini

# Optional: a GitHub token raises API rate limits and allows reading private repos.
# GITHUB_TOKEN=ghp_...
